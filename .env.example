# ── 0G Compute (AI inference) ───────────────────────────────────────────────
# BREACH runs all AI on 0G's decentralized compute via the OpenAI-compatible
# Router. Without a key the game still runs on a local fallback range, but the
# whole point ("AI-native on 0G") needs this set.
#
# Get a key:
#   1. Go to https://pc.0g.ai and connect a wallet (MetaMask or social login).
#   2. Fund it with testnet 0G from https://faucet.0g.ai (0.1 0G/day).
#      Network: 0G Galileo Testnet · Chain ID 16602 · RPC https://evmrpc-testnet.0g.ai
#   3. Deposit a little 0G to the Router and mint an API key (sk-...).
ZG_ROUTER_API_KEY=

# Optional overrides:
# Router base URL
ZG_ROUTER_BASE_URL=https://router-api.0g.ai/v1
# Model id — live options (GET https://router-api.0g.ai/v1/models):
#   deepseek-v4-flash  (default; cheap + fast, ideal for the game loop)
#   deepseek-v3 · deepseek-v4-pro · glm-5
#   0gm-1.0-35b-a3b    (0G's own in-house model; cheapest, thinking-by-default)
# NOTE: on TESTNET the Router serves only qwen/qwen2.5-omni-7b.
ZG_MODEL=deepseek-v4-flash

# ── 0G Storage (global leaderboard, optional) ────────────────────────────────
# Leaderboard persists to 0G's decentralized KV store. Writes are signed by an
# app-owned BURNER wallet (NOT a user wallet) funded with testnet 0G.
# Generate a fresh key (e.g. `node -e "console.log(require('ethers').Wallet.createRandom().privateKey)"`)
# and fund its address at https://faucet.0g.ai. Leave blank to run the board
# in local-only mode (no persistence).
ZG_PRIVATE_KEY=
ZG_STORAGE_RPC=https://evmrpc-testnet.0g.ai
ZG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
# Override only if these move:
# ZG_FLOW_CONTRACT=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296
# ZG_KV_NODE=http://3.101.147.150:6789
